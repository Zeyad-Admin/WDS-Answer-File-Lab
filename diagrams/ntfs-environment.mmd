graph TB
    subgraph DOMAIN["ACTIVE DIRECTORY DOMAIN"]
        subgraph DC["DC1 - Domain Controller"]
            AD["Active Directory<br/>Users & Groups"]
            DNS["DNS Server"]
            GPO["Group Policy<br/>Mapped Drives"]
        end

        subgraph FS["FS1 - File Server"]
            SHARE["CompanyData$ Share<br/>Hidden Share"]
            subgraph FOLDERS["Directory Structure"]
                IT_MGMT["IT_Management"]
                IT_SD["IT_ServiceDesk"]
                FIN_CTRL["Fin_Controllers"]
                FIN_ACCT["Fin_Accounting"]
            end
        end

        subgraph CLIENT["WIN10 - Windows 10 Client"]
            USER_LOGIN["Domain User Login<br/>Test Access"]
            MAPPED["Mapped Drive<br/>via Group Policy"]
        end
    end

    AD --> GPO
    GPO --> MAPPED
    DC --> FS
    SHARE --> IT_MGMT
    SHARE --> IT_SD
    SHARE --> FIN_CTRL
    SHARE --> FIN_ACCT
    USER_LOGIN --> MAPPED
    MAPPED --> SHARE

    classDef dc fill:#4dabf7,stroke:#1864ab,color:#fff,stroke-width:2px
    classDef fs fill:#69db7c,stroke:#2b8a3e,color:#fff,stroke-width:2px
    classDef folder fill:#ffa94d,stroke:#d9480f,color:#fff,stroke-width:2px
    classDef client fill:#e599f7,stroke:#9c36b5,color:#fff,stroke-width:2px

    class AD,DNS,GPO dc
    class SHARE fs
    class IT_MGMT,IT_SD,FIN_CTRL,FIN_ACCT folder
    class USER_LOGIN,MAPPED client
