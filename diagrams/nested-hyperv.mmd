graph TB
    subgraph PHYSICAL["LAYER 1 - PHYSICAL HOST"]
        HOST_OS["Windows Client<br/>Hyper-V Role Enabled<br/>Physical Hardware"]
    end

    subgraph L1_HYPERVISOR["LAYER 1 - CLIENT HYPERVISOR"]
        HV_CLIENT["Hyper-V Manager<br/>Virtual Switch<br/>VM Management"]
    end

    subgraph NESTED_VM["LAYER 2 - NESTED HYPERVISOR VM"]
        subgraph SERVER_VM["Windows Server VM"]
            SERVER_OS["Windows Server<br/>Full Installation"]
            HV_ROLE["Hyper-V Role<br/>Server Manager > Add Roles"]
            VSWITCH_NESTED["Virtual Switch<br/>Internal Network"]
        end
    end

    subgraph L2_GUESTS["LAYER 2 - NESTED GUEST VMs"]
        GUEST_VM["Guest VM<br/>Inside Nested Hypervisor<br/>Boots Successfully<br/>LAN Communication"]
    end

    subgraph NETWORK["NETWORK CONNECTIVITY"]
        LAN["LAN Network<br/>All VMs Communicate<br/>Physical to Nested"]
    end

    HOST_OS --> HV_CLIENT
    HV_CLIENT --> SERVER_VM
    SERVER_OS --> HV_ROLE
    HV_ROLE --> VSWITCH_NESTED
    VSWITCH_NESTED --> GUEST_VM
    HV_CLIENT --> LAN
    GUEST_VM --> LAN

    classDef physical fill:#868e96,stroke:#495057,color:#fff,stroke-width:3px
    classDef hypervisor fill:#4dabf7,stroke:#1864ab,color:#fff,stroke-width:2px
    classDef server fill:#69db7c,stroke:#2b8a3e,color:#fff,stroke-width:2px
    classDef guest fill:#ffa94d,stroke:#d9480f,color:#fff,stroke-width:2px
    classDef network fill:#fcc419,stroke:#e67700,color:#333,stroke-width:2px

    class HOST_OS physical
    class HV_CLIENT hypervisor
    class SERVER_OS,HV_ROLE,VSWITCH_NESTED server
    class GUEST_VM guest
    class LAN network
